# ─────────────────────────────────────────────────────────────────────────────
# FatakPay TMS — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL — GCP VM IP or domain where backend is deployed (no trailing slash)
# This is baked into the build at docker build time via VITE_ prefix
VITE_API_URL=http://<backend-gcp-vm-ip>:8000
# If backend is behind a domain:
# VITE_API_URL=https://api.yourdomain.com
