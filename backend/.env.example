# ─────────────────────────────────────────────────────────────────────────────
# FatakPay TMS — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-to-50-plus-random-chars-xxxxxxxxxxxxxxxxxxxx
DEBUG=False

# ── Database — PostgreSQL ─────────────────────────────────────────────────────
# Schemas used: identity | core | ai | audit | system
# Run scripts/init_db.sql on your PostgreSQL server before first migrate.
DB_NAME=fatakpay_tms
DB_USER=fatakpay_app
DB_PASSWORD=<your-postgres-password>
DB_HOST=<your-postgres-host>
DB_PORT=5432

# ── Hosts & CORS ──────────────────────────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1,<your-gcp-vm-ip>,<your-domain.com>
CORS_ALLOWED_ORIGINS=http://<frontend-ip>,https://<frontend-domain>

# ── Redis / Celery ────────────────────────────────────────────────────────────
CELERY_ENABLED=False
# Set True and uncomment when Redis is ready:
# CELERY_ENABLED=True
# REDIS_URL=redis://redis:6379/0

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=FatakPay TMS <noreply@fatakpay.com>

# ── File Storage ──────────────────────────────────────────────────────────────
USE_S3=False

# ── AI Engine ─────────────────────────────────────────────────────────────────
AI_SERVICE_ENABLED=True
AI_BACKEND=groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_CHAT_MODEL=llama-3.1-8b-instant
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_RESET_TIMEOUT=120
AI_REQUEST_TIMEOUT=15
AI_RATE_LIMIT_PER_USER_DAY=200
AI_RATE_LIMIT_PER_IP_MINUTE=20
